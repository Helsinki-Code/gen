# ═══════════════════════════════════════════════════════════════════════════
#  AmroGen — Environment Variables
#  Run ./setup.sh to be guided through filling this in and auto-deploying.
# ═══════════════════════════════════════════════════════════════════════════

# ── GCP Deployment ──────────────────────────────────────────────────────────
# Your Google Cloud project ID (find it at console.cloud.google.com)
GCP_PROJECT_ID=

# GCP region to deploy all services (Cloud Run, Redis, Artifact Registry)
GCP_REGION=us-central1

# ── Database (preferred: DB_* — Cloud Run / Neon) ───────────────────────────
# Do NOT set DATABASE_URL or REDIS_URL on Cloud Run; they are unused red herrings.
DB_HOST=ep-xxx.us-east-1.aws.neon.tech
DB_PORT=5432
DB_NAME=amrogen_prod_db
DB_USER=amrogen_prod_user
DB_PASSWORD=
DB_SSL=true
# Optional local docker-compose only:
# DATABASE_URL=postgresql+asyncpg://amro:amropass@localhost:5432/amrogen

# ── Auth & Security ─────────────────────────────────────────────────────────
# Secret used to sign JWTs — must be a long random string (64+ chars)
# Generate with: openssl rand -hex 32
JWT_SECRET=

# AES encryption key for storing OAuth tokens — must be exactly 32 characters
# Generate with: openssl rand -base64 24 | cut -c1-32
LOCAL_ENCRYPTION_KEY=

# Comma-separated email addresses that get admin access
ADMIN_EMAILS=you@yourdomain.com

# When true, allowlisted admins must complete MFA even in development
# (default local/dev skips MFA for admins unless this is true)
FORCE_MFA_FOR_ADMIN=true

# JWT session lifetime (days)
JWT_EXPIRY_DAYS=7

# Account discovery (optional — off by default)
# Template: agent-templates/amrogen-account-discovery.yaml
# ACCOUNT_DISCOVERY_ENABLED=false
# DISCOVERY_AGENT_ID=
# DISCOVERY_ENV_ID=
# DISCOVERY_AGENT_VERSION=1
# DISCOVERY_MAX_ACCOUNTS=100
# DISCOVERY_ACTIVE_RUNS_PER_USER=2
# DISCOVERY_SHARD_SIZE=25
# DISCOVERY_QUERIES_PER_SHARD=5

# ── Anthropic AI ────────────────────────────────────────────────────────────
# API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Anthropic Managed Agents — create under the AmroGen Anthropic org only.
# Specs: claude-agents.md / Claude_Agents.pdf. Paste IDs after Console create.
# Do NOT reuse third-party (e.g. contractor) agent or vault IDs.
LEAD_AGENT_ID=
LEAD_AGENT_VERSION=1
LEAD_ENV_ID=

OUTREACH_AGENT_ID=
OUTREACH_AGENT_VERSION=1
OUTREACH_ENV_ID=

EMAIL_AGENT_ID=
EMAIL_AGENT_VERSION=1
EMAIL_ENV_ID=

SMS_AGENT_ID=
SMS_AGENT_VERSION=1
SMS_ENV_ID=

REPLY_MONITOR_AGENT_ID=
REPLY_MONITOR_AGENT_VERSION=1
REPLY_MONITOR_ENV_ID=

ORCHESTRATOR_AGENT_ID=
ORCHESTRATOR_AGENT_VERSION=1
ORCHESTRATOR_ENV_ID=

COORDINATOR_AGENT_ID=
COORDINATOR_ENV_ID=

# Vault holding PARALLEL_API_KEY (attach to Lead Gen agent)
VAULT_IDS=
# Parallel credential inside that vault (Console reference only; not sent to sessions)
PARALLEL_CREDENTIAL_ID=

# ── Resend (Transactional Email) ─────────────────────────────────────────────
# API key from https://resend.com — used for OTP / password reset emails
RESEND_API_KEY=re_...

# "From" address — must be from a domain verified in your Resend account
RESEND_FROM_EMAIL=AmroGen <noreply@yourdomain.com>

# Daily ops digest (activity + failures) → info@amrogen.com
# Procrastinate: 08:00 UTC. HTTP: POST /internal/cron/daily-digest
# Authorization: Bearer {CRON_SECRET}
CRON_SECRET=
DAILY_DIGEST_TO=info@amrogen.com
DAILY_DIGEST_ENABLED=true

# From address for admin article workflow notifications
ARTICLE_NOTIFY_FROM=AmroGen <vikram@yourdomain.com>

# ── Stripe (Payments & Subscriptions) ────────────────────────────────────────
# Test mode: use sk_test_... (can match Academy). See docs/STRIPE-TEST-SETUP.md
STRIPE_SECRET_KEY=sk_test_...
# Leave empty in local dev to use confirm-session fallback; or use Stripe CLI whsec_...
STRIPE_WEBHOOK_SECRET=
# AmroGen frontend origin for Checkout success/cancel redirects
FRONTEND_URL=http://localhost:3001

# Price IDs — create GBP recurring prices in Stripe test dashboard
STRIPE_PRICE_STARTER=price_...        # Starter 10-pack £5,399 one-time → 80 credits
STRIPE_PRICE_PROFESSIONAL=price_...   # Professional 10-pack £25,492 one-time → 80 credits
STRIPE_PRICE_ENTERPRISE=price_...     # Enterprise 10-pack £39,992 one-time → 80 credits

# ── Google OAuth (Gmail Sending Integration) ──────────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs must include your backend Cloud Run URL + /gmail/callback
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# This is auto-updated by deploy.sh to use the Cloud Run API URL
GOOGLE_REDIRECT_URI=https://YOUR-API-URL.run.app/gmail/callback

# ── Google Cloud Storage (Campaign File Storage) ───────────────────────────
# GCS bucket name for storing campaign outputs
GCS_BUCKET_NAME=amrogen-campaigns

# Path to GCP service account JSON key file (download from GCP IAM)
# The deploy script reads this file and stores it securely in Secret Manager
GOOGLE_APPLICATION_CREDENTIALS=./backend/secrets/gcp-key.json

# ── Gemini (TTS / Podcast Studio / Article Audio) ─────────────────────────
# API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Gemini model names (defaults are fine — only change if newer models release)
GEMINI_TTS_MODEL=gemini-2.5-pro-preview-tts
GEMINI_ASSISTANT_MODEL=gemini-3.1-pro-preview
GEMINI_ARTICLE_MODEL=gemini-3.1-pro-preview
GEMINI_ARTICLE_TTS_MODEL=gemini-2.5-pro-preview-tts
GEMINI_ARTICLE_TTS_VOICE=Leda

# ── OpenAI (Article Image Generation) ────────────────────────────────────────
# API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1536x1024

# ── App Settings ──────────────────────────────────────────────────────────────
ENVIRONMENT=production

# These are auto-set by deploy.sh after Cloud Run services are created
API_BASE_URL=https://YOUR-API-URL.run.app
FRONTEND_URL=https://YOUR-FRONTEND-URL.run.app

# Redis — NOT used on Cloud Run (Procrastinate/Postgres worker). Do not set REDIS_URL.

# ── Frontend (Next.js public vars — baked into the frontend build) ───────────
# Same as API_BASE_URL — auto-set by deploy.sh
NEXT_PUBLIC_API_URL=https://YOUR-API-URL.run.app
NEXT_PUBLIC_APP_URL=https://YOUR-FRONTEND-URL.run.app
NEXT_PUBLIC_SITE_URL=https://YOUR-FRONTEND-URL.run.app

# ── Frontend runtime (also in frontend/.env.production for Cloud Run) ─────────
# RESEND_API_KEY=re_...              # bookings + article workflow
# RESEND_FROM_EMAIL=AmroGen <noreply@yourdomain.com>
# BOOKING_NOTIFY_EMAIL=hello@agentic-ai.ltd

# ── MCP server (separate process — see mcp/.env.example) ─────────────────────
# BACKEND_API_URL=https://YOUR-API-URL.run.app
# AMROGEN_API_KEY=amro_sk_...
# MCP_PORT=8001
