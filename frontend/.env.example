# AmroGen frontend environment variables
# ─────────────────────────────────────────────────────────────────────────────
# .env.local       → local dev (`npm run dev`)
# .env.production  → production build + Cloud Run deploy (deploy-production.ps1)
# Do not commit real values.

# ── Required (both .env.local and .env.production) ───────────────────────────

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# This Next.js app URL (serverActions allowedOrigins in next.config.ts)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public marketing / SEO canonical URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Amro Agents embed (chat widget on marketing pages) — bot ID from Amro Agents dashboard
# NEXT_PUBLIC_AMROBOT_CHATBOT_ID=your-bot-uuid
# Optional override: NEXT_PUBLIC_AMROBOT_WIDGET_SCRIPT_URL=https://amroagents.com/widget-loader.js

# ── .env.production example values (Cloud Run) ───────────────────────────────
# NEXT_PUBLIC_API_URL=https://amrogen-backend-zgoudwucaq-ew.a.run.app
# NEXT_PUBLIC_APP_URL=https://amrogen.com
# NEXT_PUBLIC_SITE_URL=https://amrogen.com

# ── Bookings & transactional email (consultation form via Resend) ────────────
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=AmroGen <onboarding@resend.dev>
# BOOKING_NOTIFY_EMAIL=hello@agentic-ai.ltd

# ── Optional runtime secrets (.env.production → deploy/env.cloudrun.yaml) ───
# Used by admin article workflow (server-side). Can also live in ../backend/.env
# GEMINI_API_KEY=
# GEMINI_ARTICLE_MODEL=gemini-3.1-pro-preview
# OPENAI_API_KEY=
# RESEND_API_KEY=
# ARTICLE_NOTIFY_FROM=AmroGen <onboarding@resend.dev>
